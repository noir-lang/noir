    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "mocha": "^11.7.5",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "0.28.0"
  }
