// A mini "validation" attribute (the shape of a `Validate` derive, but spelled out by hand):
// pass it a checking function by name, and it
//   1. receives that function as a `FunctionDefinition` (https://github.com/noir-lang/noir/issues/13186),
//   2. verifies the function's signature,
//   3. emits a `validate_*` entry point that calls it, and
//   4. that entry point is invoked at runtime, actually running the check.

#[validate_with(check_percent)]
pub struct Percent {
    value: u32,
}

// The hand-written invariant for `Percent`.
pub fn check_percent(p: Percent) {
    assert(p.value <= 100);
}

comptime fn validate_with(s: TypeDefinition, check: FunctionDefinition) -> Quoted {
    let typ = s.as_type();

    // (2) Verify the checker's signature: it must take exactly one argument, and that argument
    // must be the type the attribute was placed on.
    let params = check.parameters();
    assert(params.len() == 1, "a validation function must take exactly one argument");
    assert(params[0].1 == typ, "the validation function must take the annotated type");

    // (3) Emit a validator that calls the checker.
    let check_name = check.name();
    quote {
        pub fn validate_percent(p: $typ) {
            $check_name(p)
        }
    }
}

fn main(value: u32) {
    let p = Percent { value };
    // (4) `validate_percent` was generated by the attribute and calls `check_percent` here.
    validate_percent(p);
}
