use noir_edwards::bjj::BabyJubJub;
use noir_edwards::CurveTrait;

fn main() {
    // Define Baby Jubjub points
    let p1: BabyJubJub = BabyJubJub::new(
        17777552123799933955779906779655732241715742912184938656739573121738514868268,
        2626589144620713026669568689430873010625803728049924121243784502389097019475,
    );
    let p2: BabyJubJub = BabyJubJub::new(
        16540640123574156134436876038791482806971768689494387082833631921987005038935,
        20819045374670962167435360035096875258406992893633759881276124905556507972311,
    );
    let _p3 = p1 + p2;

    // Check that a point is on the curve
    assert(p1.is_on_curve());
}
