use std::hash::poseidon2_permutation;

unconstrained fn main(input1: [Field; 16], input2: [Field; 4], flag: bool) -> pub Field {
    if flag {
        poseidon2_permutation(input1, 16_u32)[0_u32]
    } else {
        poseidon2_permutation(input2, 4_u32)[0_u32]
    }
}
