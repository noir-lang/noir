fn main() -> pub bool {
    foo()
}

fn foo() -> bool {
    bar([&mut true])
}

fn bar(a: [&mut bool; 1]) -> bool {
    let c: [&mut bool; 2] = [a[0_u32], &mut true];
    let idx: u32 = if *c[0_u32] { 1_u32 } else { 0_u32 };
    *c[idx]
}
