expression: expanded_code
---
fn main(arr: [u32; 1], cond: bool) {
    let slice: [u32] = arr.as_slice();
    let (empty, _): ([u32], u32) = slice.remove(0_u32);
    if cond {
        let inserted: [u32] = empty.insert(0_u32, 5_u32);
        assert(inserted.len() == 1_u32);
    }
}
