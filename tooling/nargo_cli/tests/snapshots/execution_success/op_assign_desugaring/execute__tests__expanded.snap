fn main() {
    let mut x: [Field; 3] = [1_Field, 2_Field, 3_Field];
    {
        let i_0: u32 = {
            x[0_u32] = x[0_u32] + 2_Field;
            0_u32
        };
        x[i_0] = x[i_0] + 3_Field;
    };
    assert(x[0_u32] == ((1_Field + 2_Field) + 3_Field));
