pub struct Foo {}

trait Bar {
    fn bar(self) -> u32;
}

mod impls {
    use crate::{Bar, Foo};

    impl Foo {
        fn secret(self) -> u32 {
            let _: Self = self;
            42_u32
        }
    }

    impl Bar for Foo {
        fn bar(self) -> u32 {
            self.secret()
        }
    }
}

fn main() {
    assert(Foo {}.bar() == 42_u32);
}
