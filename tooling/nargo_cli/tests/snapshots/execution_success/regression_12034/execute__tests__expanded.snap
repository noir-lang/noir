pub fn main(x: Field) {
    let scalar: std::embedded_curve_ops::EmbeddedCurveScalar =
        std::embedded_curve_ops::EmbeddedCurveScalar { lo: x, hi: 0_Field };
    let point: std::embedded_curve_ops::EmbeddedCurvePoint =
        std::embedded_curve_ops::fixed_base_scalar_mul(scalar);
    assert(point.x != 0_Field);
}
