use std::meta::ctstring::AsCtString;

#['some_attribute]
#['another_attribute]
pub struct SomeStruct {
    a: Field,
    b: Field,
}

fn main() {}

contract moo {
    #[abi(foo)]
    pub struct Foo {}
}

comptime fn add_attribute(s: TypeDefinition) {
    assert(!s.has_named_attribute("abi"));
    s.add_abi("foo".as_ctstring());
    assert(s.has_named_attribute("abi"));
}
