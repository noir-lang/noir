pub fn main(inp: Field) {
    if inp == 1_Field {
        let scalar: std::embedded_curve_ops::EmbeddedCurveScalar = std::embedded_curve_ops::EmbeddedCurveScalar::from_field(
            340282366920938463463374607431768211456_Field,
        );
        let point: std::embedded_curve_ops::EmbeddedCurvePoint =
            std::embedded_curve_ops::fixed_base_scalar_mul(scalar);
        assert(point.x != 0_Field);
    }
}
