pub trait RuntimeState<Context> {
    type Runtime;
}

pub struct PublicMutable<T> {}

impl<Context, T> RuntimeState<Context> for PublicMutable<T> {
    type Runtime = RuntimePublicMutable<T, Context>;
}

pub struct RuntimePublicMutable<T, Context> {
    pub context: Context,
    pub slot: Field,
}

pub struct ContextType {}

pub struct Storage {
    pub value: RuntimePublicMutable<u128, ContextType>,
}

fn main() {
    let _: Storage = Storage {
        value: RuntimePublicMutable::<u128, ContextType> { context: ContextType {}, slot: 0_Field },
    };
}
